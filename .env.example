# --- SEGURANÇA ---
ADMIN_USER=admin
ADMIN_PASS=sua_senha_aqui

# --- EMAIL (SendGrid) ---
SENDGRID_API_KEY=sua_chave_sendgrid_aqui
EMAIL_REMETENTE=seu_email@example.com

# --- COMUNICAÇÃO ---
# CallMeBot API Key para envio de mensagens WhatsApp
CALLMEBOT_API_KEY=sua_chave_callmebot_aqui

# --- PAGAMENTOS ---
# MercadoPago PIX Integration
MP_ACCESS_TOKEN=seu_token_mercadopago_aqui

# --- SERVIDOR ---
# Base URL do servidor (ajuste o IP para seu ambiente)
BASE_URL=http://192.168.0.17:8080
